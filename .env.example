# Local development settings
# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production (easytrackmanager.com) - add to .env on server:
# ALLOWED_HOSTS=20.251.154.94,easytrackmanager.com,www.easytrackmanager.com
# CSRF_TRUSTED_ORIGINS=https://easytrackmanager.com,https://www.easytrackmanager.com
CSRF_TRUSTED_ORIGINS=
# Set USE_SQLITE=True for local dev without PostgreSQL
USE_SQLITE=True

# PostgreSQL
POSTGRES_DB=cloudcomputing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

# Docker Hub (for deployment - set in GitHub Secrets)
# Use your Docker Hub username, e.g. 00015829
DOCKERHUB_USERNAME=00015829
